    Warning:            #D97706  / bg #FFF7ED / border #FED7AA                                                                                                                                  
    Error:              #DC2626  / bg #FEF2F2 / border #FECACA                                                                                                                                  
    Info blue:          #2563EB  / bg #EFF6FF / border #BFDBFE                                                                                                                                  
                                                                                                                                                                                                
