# Database (Supabase)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Token encryption (generate: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Seed (min 12 chars)
SEED_PASSWORD="change-me-min-12-chars"

# Cloudflare R2
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="rise-assets"

# Remotion render — Option A (local CLI, fără microservice)
# Nu sunt necesare în Phase 1 — render-ul se face local cu npx remotion render
# RENDER_SERVICE_URL="http://localhost:3001"
# RENDER_WEBHOOK_SECRET="..."
# REDIS_URL="redis://localhost:6379"

# Meta Ads (Sub-proiect 4)
# Cron secret: openssl rand -hex 32
CRON_SECRET="generate-with-openssl-rand-hex-32"
# Cron schedule (Dokploy VPS):
#   0 6 * * * curl -X POST https://rise.azora.ro/api/meta/sync-metrics -H "Authorization: Bearer $CRON_SECRET" -H "Content-Type: application/json" -d '{}'
#   5 6 * * * curl -X POST https://rise.azora.ro/api/meta/sync -H "Authorization: Bearer $CRON_SECRET" -H "Content-Type: application/json" -d '{}'
#   0 18 * * * curl -X POST https://rise.azora.ro/api/meta/sync -H "Authorization: Bearer $CRON_SECRET" -H "Content-Type: application/json" -d '{}'

# Claude API (Sub-proiect 5 — Hook Generator AI)
# ANTHROPIC_API_KEY="sk-ant-..."

# Firecrawl — scraping URL → JSON structurat (Sub-proiect Listing AI, după subscripții)
# Plan gratuit: 500 credite/lună — https://firecrawl.dev
# FIRECRAWL_API_KEY="fc-..."

# Resend (email notifications — Returns)
RESEND_API_KEY=re_...
ADMIN_EMAIL=contact@azora.ro
